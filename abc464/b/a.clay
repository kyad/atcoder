int@H,@W;
VS@C(H);
int X[W],Y[H];X[0..W-1]=0;Y[0..H-1]=0;
rep(y,H)rep(x,W)if(C[y][x]=='#')Y[y]++,X[x]++;
int l=0,r=W-1,t=0,b=H-1;
while(true){if(X[l]==0)l++;else break;}
while(true){if(X[r]==0)r--;else break;}
while(true){if(Y[t]==0)t++;else break;}
while(true){if(Y[b]==0)b--;else break;}
rep(y,t,b+1)wt(C[y].substr(l,r-l+1));
