int@T;
rep(T){
  int@N;
  string@S;
  int@X[N],@Y[N-1];
  ll Z[N];
  rep(i,1,N){
    if(S[i-1]=='R'&&S[i]=='R')Z[i]=-X[i]+Y[i-1];
    else if(S[i-1]=='R'&&S[i]=='S')Z[i]=Y[i-1];
    else if(S[i-1]=='S'&&S[i]=='R')Z[i]=-X[i-1]-X[i]+Y[i-1];
    else Z[i]=-X[i-1]+Y[i-1];
  }
  ll dp[N][2];dp[0..N-1][0...1]=-ll_inf;
  dp[0][0]=0;
  rep(i,1,N){
    rep(j,2)dp[i][0]>?=dp[i-1][j];
    dp[i][1]>?=dp[i-1][0]+Z[i];
  }
  wt(max(dp[N-1](2)));
}
