ll@N,@K,N2=1<<N,@P[N],@C[N][N],dp[N2][N],s,S,t,r=-4e18;dp[0..N2-1][0...N-1]=r;rep(u,N)dp[1<<u][u]=0;auto f=[&](int b)->int{t=-1;for(int i=0;i<N;i++)if(b>>i&1){t=i;break;}return t;};rep(b,1,N2){s=f(b);rep(i,N){if(!(b>>i&1))continue;rep(j,s+1,N){if(b>>j&1)continue;dp[b|1<<j][j]>?=dp[b][i]+C[i][j];}}}rep(b,N2){if(BIT_popcount(b)!=K)continue;s=f(b);S=0;rep(u,N)if(b>>u&1)S+=P[u];rep(u,N){if(!(b>>u&1))continue;r>?=dp[b][u]+C[s][u]+S;}}wt(r);
