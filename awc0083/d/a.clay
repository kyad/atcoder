ll@(H,W,N),M=H*W,dy[4]={0,-1,0,1},dx[4]={1,0,-1,0},u;VS S(H,string(W,'.'));rep(i,N){int@R--,@C--;S[R][C]='#';}VVI g(M);rep(r,H)rep(c,W)rep(k,4){ll y=r,x=c,z=y*W+x;for(;;){ll ny=y+dy[k],nx=x+dx[k];if(0<=ny<H&&0<=nx<W&&S[ny][nx]=='.')y=ny,x=nx; else break;}g[z].push_back(y*W+x);}queue<ll>q;ll d[M];d[0..M-1]=-1;d[0]=0;q.push(0);while(!q.empty()){u=q.front();q.pop();for(ll v:g[u])if(d[v]<0)d[v]=d[u]+1,q.push(v);}wt(d[(H-1)*W+W-1]);
