using S = pair<ll,int>;S segtree_rh_merge(S a,S b){return min(a,b);}S segtree_rh_apply(ll f,S x){return {f+x.first,x.second};}ll segtree_rh_compose(ll f,ll g){return f+g;}{ll@(T,N,D,Q),@(L[N],R[N]),M=T-D+1;segtree_rh<S,ll>t;t.malloc(M);t.setN(M,0,0);rep(i,M)t[i]={0,i};t.build();rep(i,N)if(R[i]-L[i]<=D)t.change(max(0,R[i]-D),min(T-D,L[i])+1,1);rep(Q){ll@m--;if(m){S res=t.get(0,M);wt(res.second, res.first);}else{ll@(i--,l,r);if(R[i]-L[i]<=D)t.change(max(0,R[i]-D),min(T-D,L[i])+1,-1);L[i]=l,R[i]=r;if(R[i]-L[i]<=D)t.change(max(0,R[i]-D),min(T-D,L[i])+1,1);}}}
