int f(char c){
  if (c<='c'){
    return 2;
  }else if(c<='f'){
    return 3;
  }else if(c<='i'){
    return 4;
  }else if(c<='l'){
    return 5;
  }else if(c<='o'){
    return 6;
  }else if(c<='s'){
    return 7;
  }else if(c<='v'){
    return 8;
  }else if(c<='z'){
    return 9;
  }else{
    return -1;
  }
}
{
  int@N;
  rep(N){
    string@S;
    printf("%d",f(S[0]));
  }
}
